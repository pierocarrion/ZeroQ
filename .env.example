# ============================================================
# ZeroQ (Next.js) — environment configuration
# Copy to .env.local and fill in. Everything works without these
# (uses public APIs + heuristic fallbacks); set them for full power.
# ============================================================

# ---- AI (server-side reasoning for Assistant + Org Plan) ----
# Without a key the app falls back to a deterministic local reasoner.
# DeepSeek (recommended): https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# AI_PROVIDER=deepseek   # deepseek | local | splunk

# ---- Source tokens (optional — raises rate limits + allows private repos) ----
# Public repos scan with no token (GitHub 60 req/hr unauthenticated).
# Just set GITHUB_ORG to scan public repos of an organization.
GITHUB_ORG=
GITHUB_TOKEN=
GITLAB_TOKEN=

# ---- Splunk HEC (write findings) ----
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
SPLUNK_INDEX_SOURCE=crypto_source

# ---- Splunk REST API (read posture data from Splunk Cloud/Enterprise) ----
# Required for live dashboards. If omitted, the app falls back to seed/demo data.
SPLUNK_BASE_URL=
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
# SPLUNK_SKIP_TLS_VERIFY=true   # only for local dev with untrusted Splunk certs
SPLUNK_INDEX_NET=crypto_net
SPLUNK_INDEX_PKI=crypto_pki
SPLUNK_INDEX_HNDL=crypto_hndl
SPLUNK_INDEX_PLAN=crypto_plan

# ---- Scan behavior ----
SCAN_MAX_FILES=80
